{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Otto Canvas",
	"version": "0.1.0",
	"identifier": "io.ottocode.canvas",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1430",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "Otto Canvas",
				"width": 1400,
				"height": 900,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"transparent": true,
				"backgroundColor": "#00000000",
				"titleBarStyle": "Overlay",
				"decorations": true,
				"hiddenTitle": true,
				"trafficLightPosition": {
					"x": 16,
					"y": 22
				},
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["dmg", "app"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
